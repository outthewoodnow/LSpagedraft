<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Life Skills Full Program — Cross Academy LMS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">

  <style>
    /* ===========================
       VARIABLES
    =========================== */
    :root {
      --blue:      #4AA0D7;
      --navy:      #1D3866;
      --navy-dark: #162a50;
      --black:     #111111;
      --white:     #FFFFFF;
      --warm-bg:   #F7F5F2;
      --warm-mid:  #EDEBE7;
      --text:      #2C2C2C;
      --muted:     #6B6B6B;
      --border:    #E0DDD8;

      --font-display: 'Barlow Condensed', sans-serif;
      --font-body:    'DM Sans', sans-serif;
      --max:          1060px;
    }

    /* ===========================
       RESET
    =========================== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font-body);
      background: var(--white);
      color: var(--text);
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
    }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }

    .container {
      max-width: var(--max);
      margin: 0 auto;
      padding: 0 28px;
    }

    /* ===========================
       SHARED
    =========================== */
    .eyebrow {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: 14px;
    }

    h2.section-title {
      font-family: var(--font-display);
      font-size: clamp(30px, 4vw, 46px);
      font-weight: 700;
      color: var(--text);
      line-height: 1.1;
      margin-bottom: 16px;
      letter-spacing: -0.01em;
    }

    .section-sub {
      font-size: 1rem;
      color: var(--muted);
      line-height: 1.7;
      max-width: 560px;
    }

    section { padding: 84px 28px; }

    /* ===========================
       BUTTONS
    =========================== */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-family: var(--font-body);
      font-weight: 600;
      font-size: 0.9375rem;
      letter-spacing: 0.02em;
      cursor: pointer;
      transition: all 0.2s;
      padding: 15px 36px;
      border-radius: 3px;
    }
    .btn-blue {
      background: var(--blue);
      color: var(--white);
    }
    .btn-blue:hover { background: #3a8fc6; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(74,160,215,0.35); }

    .btn-outline-white {
      background: transparent;
      color: rgba(255,255,255,0.85);
      border: 1.5px solid rgba(255,255,255,0.4);
    }
    .btn-outline-white:hover { border-color: rgba(255,255,255,0.9); color: var(--white); }

    .btn-white {
      background: var(--white);
      color: var(--navy);
    }
    .btn-white:hover { background: #f0f0f0; transform: translateY(-1px); }

    .btn-lg { padding: 18px 48px; font-size: 1rem; }

    .btn-full {
      display: flex;
      width: 100%;
      background: var(--blue);
      color: var(--white);
      font-family: var(--font-body);
      font-weight: 600;
      font-size: 1rem;
      letter-spacing: 0.02em;
      padding: 18px 36px;
      border-radius: 3px;
      justify-content: center;
      align-items: center;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-full:hover { background: #3a8fc6; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(74,160,215,0.3); }

    /* ===========================
       HERO
    =========================== */
    .hero {
      position: relative;
      min-height: 92vh;
      display: flex;
      flex-direction: column;
      padding: 0;
    }

    /* ★ IMAGE PLACEHOLDER — replace background-color with background-image: url('YOUR_IMAGE_URL') */
    .hero-bg {
      position: absolute;
      inset: 0;
      background-color: #3a5a80;
      /* background-image: url('YOUR_HERO_IMAGE_URL_HERE');
         background-size: cover;
         background-position: center top; */
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(29, 56, 102, 0.82) 0%,
        rgba(29, 56, 102, 0.75) 50%,
        rgba(29, 56, 102, 0.88) 100%
      );
    }

    .hero-inner {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      min-height: 92vh;
    }

    /* Minimal nav — no exits */
    .hero-nav {
      padding: 24px 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .hero-logo { height: 40px; width: auto; }

    .hero-nav-right {
      font-size: 0.8rem;
      font-weight: 500;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.06em;
    }

    /* Hero content centered */
    .hero-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 48px 28px 72px;
      max-width: 760px;
      margin: 0 auto;
      width: 100%;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(74,160,215,0.18);
      border: 1px solid rgba(74,160,215,0.38);
      color: #8ec8ea;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 7px 18px;
      border-radius: 100px;
      margin-bottom: 28px;
    }

    .hero-headline {
      font-family: var(--font-display);
      font-size: clamp(40px, 6.5vw, 72px);
      font-weight: 700;
      color: var(--white);
      line-height: 1.05;
      letter-spacing: -0.01em;
      margin-bottom: 22px;
    }

    .hero-sub {
      font-size: 1.0625rem;
      color: rgba(255,255,255,0.72);
      line-height: 1.68;
      max-width: 560px;
      margin: 0 auto 40px;
    }

    .hero-ctas {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      justify-content: center;
      margin-bottom: 48px;
    }

    /* Offer strip */
    .hero-strip {
      display: flex;
      align-items: center;
      gap: 10px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.13);
      border-radius: 4px;
      padding: 16px 32px;
    }

    .hero-strip-price {
      font-family: var(--font-display);
      font-size: 2rem;
      font-weight: 700;
      color: var(--white);
    }

    .hero-strip-divider {
      width: 1px;
      height: 28px;
      background: rgba(255,255,255,0.2);
      margin: 0 6px;
    }

    .hero-strip-detail {
      text-align: left;
      font-size: 0.8125rem;
      color: rgba(255,255,255,0.65);
      line-height: 1.4;
    }

    .hero-strip-detail strong {
      display: block;
      font-weight: 600;
      color: rgba(255,255,255,0.9);
    }

    /* ===========================
       PROBLEM
    =========================== */
    .problem {
      background: var(--warm-bg);
    }

    .problem-inner {
      max-width: var(--max);
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 72px;
      align-items: start;
    }

    .problem-copy {
      font-size: 1rem;
      color: var(--muted);
      line-height: 1.75;
      margin-bottom: 18px;
    }

    .gap-list { margin-top: 10px; }

    .gap-item {
      display: flex;
      gap: 16px;
      align-items: flex-start;
      padding: 22px 0;
      border-bottom: 1px solid var(--border);
    }
    .gap-item:first-child { border-top: 1px solid var(--border); }

    .gap-dot {
      width: 8px;
      height: 8px;
      background: var(--blue);
      border-radius: 50%;
      margin-top: 8px;
      flex-shrink: 0;
    }

    .gap-label {
      font-weight: 600;
      font-size: 0.9375rem;
      color: var(--text);
      margin-bottom: 5px;
    }

    .gap-text { font-size: 0.875rem; color: var(--muted); line-height: 1.6; }

    /* ===========================
       MODULES
    =========================== */
    .modules { background: var(--white); }

    .modules-header {
      max-width: var(--max);
      margin: 0 auto 48px;
    }

    .modules-grid {
      max-width: var(--max);
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    .module-card {
      background: var(--warm-bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 32px 28px;
      transition: box-shadow 0.2s;
    }
    .module-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.07); }

    .module-num {
      font-family: var(--font-display);
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: 10px;
    }

    .module-name {
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 18px;
      line-height: 1.2;
    }

    .module-topics { list-style: none; }
    .module-topics li {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.875rem;
      color: var(--muted);
      padding: 7px 0;
      border-bottom: 1px solid var(--border);
    }
    .module-topics li:last-child { border-bottom: none; }
    .module-topics li::before {
      content: '';
      width: 4px;
      height: 4px;
      background: var(--blue);
      border-radius: 50%;
      flex-shrink: 0;
    }

    /* ===========================
       WHO IT'S FOR
    =========================== */
    .for-whom {
      background: var(--navy);
      color: var(--white);
    }

    .for-whom-inner { max-width: var(--max); margin: 0 auto; }

    .for-whom h2.section-title { color: var(--white); margin-bottom: 44px; }

    .for-whom-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .for-whom-card {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 6px;
      padding: 36px 30px;
      transition: background 0.2s;
    }
    .for-whom-card:hover { background: rgba(255,255,255,0.08); }

    .for-whom-icon {
      width: 44px;
      height: 44px;
      background: rgba(74,160,215,0.15);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 18px;
    }
    .for-whom-icon svg {
      width: 20px; height: 20px;
      stroke: var(--blue); fill: none;
      stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
    }

    .for-whom-title {
      font-family: var(--font-display);
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 10px;
    }

    .for-whom-text { font-size: 0.9rem; color: rgba(255,255,255,0.65); line-height: 1.65; }

    /* ===========================
       OUTCOMES
    =========================== */
    .outcomes { background: var(--warm-bg); }

    .outcomes-inner {
      max-width: var(--max);
      margin: 0 auto;
    }

    .outcomes-header {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: end;
      margin-bottom: 48px;
      gap: 24px;
    }

    .outcomes-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      background: var(--border);
      border-radius: 6px;
      overflow: hidden;
    }

    .outcome-item {
      background: var(--white);
      padding: 32px 28px;
    }

    .outcome-icon {
      width: 42px;
      height: 42px;
      background: rgba(74,160,215,0.1);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
    }
    .outcome-icon svg {
      width: 18px; height: 18px;
      stroke: var(--blue); fill: none;
      stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
    }

    .outcome-title {
      font-weight: 700;
      font-size: 0.9375rem;
      color: var(--text);
      margin-bottom: 7px;
    }

    .outcome-desc { font-size: 0.875rem; color: var(--muted); line-height: 1.6; }

    /* ===========================
       PROGRAM DETAILS
    =========================== */
    .program { background: var(--white); }

    .program-inner {
      max-width: var(--max);
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
    }

    .program-copy { font-size: 1rem; color: var(--muted); line-height: 1.72; margin-bottom: 16px; }

    .program-includes { margin-top: 32px; }

    .program-includes-label {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #aaa;
      margin-bottom: 14px;
    }

    .program-includes-list { list-style: none; }
    .program-includes-list li {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 0.9375rem;
      color: var(--text);
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
    }
    .program-includes-list li:last-child { border-bottom: none; }

    .check {
      width: 20px;
      height: 20px;
      background: rgba(74,160,215,0.12);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 0.75rem;
      color: var(--blue);
      font-weight: 700;
    }

    .program-card {
      background: var(--navy);
      border-radius: 8px;
      padding: 44px 40px;
      color: var(--white);
    }

    .program-card-title {
      font-family: var(--font-display);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 12px;
    }

    .program-card-text { font-size: 0.9375rem; color: rgba(255,255,255,0.65); line-height: 1.65; margin-bottom: 28px; }

    .program-bonus {
      background: rgba(74,160,215,0.12);
      border: 1px solid rgba(74,160,215,0.25);
      border-radius: 5px;
      padding: 18px 22px;
      margin-bottom: 32px;
    }

    .program-bonus-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: 6px;
    }

    .program-bonus-text { font-size: 0.875rem; color: rgba(255,255,255,0.6); line-height: 1.5; }

    /* ===========================
       CREDIBILITY
    =========================== */
    .credibility { background: var(--warm-bg); }

    .credibility-inner {
      max-width: var(--max);
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 72px;
      align-items: start;
    }

    .credibility-copy { font-size: 1rem; color: var(--muted); line-height: 1.72; margin-bottom: 36px; }

    .pillars { list-style: none; }

    .pillar {
      display: flex;
      gap: 16px;
      align-items: flex-start;
      padding: 20px 0;
      border-bottom: 1px solid var(--border);
    }
    .pillar:first-child { border-top: 1px solid var(--border); }

    .pillar-icon {
      width: 34px;
      height: 34px;
      background: rgba(74,160,215,0.1);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .pillar-icon svg {
      width: 15px; height: 15px;
      stroke: var(--blue); fill: none;
      stroke-width: 2.2; stroke-linecap: round; stroke-linejoin: round;
    }

    .pillar-label {
      font-weight: 600;
      font-size: 0.9375rem;
      color: var(--text);
      margin-bottom: 4px;
    }
    .pillar-text { font-size: 0.875rem; color: var(--muted); }

    .founder-card {
      background: var(--navy);
      border-radius: 8px;
      padding: 44px 40px;
      color: var(--white);
    }

    .founder-tag {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--blue);
      display: block;
      margin-bottom: 18px;
    }

    .founder-name {
      font-family: var(--font-display);
      font-size: 2rem;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 4px;
    }

    .founder-role {
      font-size: 0.8rem;
      color: rgba(255,255,255,0.4);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 22px;
    }

    .founder-divider {
      height: 1px;
      background: rgba(255,255,255,0.1);
      margin-bottom: 22px;
    }

    .founder-bio { font-size: 0.9375rem; color: rgba(255,255,255,0.7); line-height: 1.68; margin-bottom: 28px; }

    .founder-accolades { list-style: none; }
    .founder-accolade {
      display: flex;
      gap: 12px;
      align-items: center;
      padding: 11px 0;
      border-top: 1px solid rgba(255,255,255,0.08);
      font-size: 0.8125rem;
      color: rgba(255,255,255,0.5);
    }
    .founder-accolade::before {
      content: '';
      width: 4px;
      height: 4px;
      background: var(--blue);
      border-radius: 50%;
      flex-shrink: 0;
    }

    /* ===========================
       PRICING
    =========================== */
    .pricing {
      background: var(--navy);
      color: var(--white);
    }

    .pricing-inner {
      max-width: 640px;
      margin: 0 auto;
      text-align: center;
    }

    .pricing h2.section-title { color: var(--white); }

    .pricing-sub {
      font-size: 1rem;
      color: rgba(255,255,255,0.6);
      margin: 0 auto 48px;
      line-height: 1.65;
    }

    .pricing-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 10px;
      padding: 52px 48px;
      position: relative;
    }

    .pricing-pill {
      display: inline-block;
      background: var(--blue);
      color: var(--white);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 6px 20px;
      border-radius: 100px;
      margin-bottom: 28px;
    }

    .pricing-name {
      font-family: var(--font-display);
      font-size: 1.375rem;
      font-weight: 700;
      color: rgba(255,255,255,0.7);
      margin-bottom: 16px;
    }

    .pricing-amount {
      font-family: var(--font-display);
      font-size: clamp(72px, 14vw, 108px);
      font-weight: 700;
      color: var(--white);
      line-height: 1;
      margin-bottom: 8px;
    }
    .pricing-amount sup {
      font-size: 0.4em;
      vertical-align: super;
      color: var(--blue);
    }

    .pricing-note {
      font-size: 0.8125rem;
      color: rgba(255,255,255,0.38);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 36px;
    }

    .pricing-rule { height: 1px; background: rgba(255,255,255,0.08); margin-bottom: 32px; }

    .pricing-list { list-style: none; text-align: left; margin-bottom: 36px; }
    .pricing-list li {
      display: flex;
      align-items: center;
      gap: 14px;
      font-size: 0.9375rem;
      color: rgba(255,255,255,0.78);
      padding: 13px 0;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .pricing-list li:last-child { border-bottom: none; }
    .pricing-list .chk {
      color: var(--blue);
      font-weight: 700;
      flex-shrink: 0;
    }

    .pricing-disclaimer {
      font-size: 0.8rem;
      color: rgba(255,255,255,0.28);
      margin-top: 18px;
    }

    /* ===========================
       FINAL CTA
    =========================== */
    .final-cta {
      background: var(--blue);
      padding: 96px 28px;
      text-align: center;
    }

    .final-cta h2.section-title {
      color: var(--white);
      font-size: clamp(32px, 5vw, 56px);
      margin-bottom: 18px;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }

    .final-cta .section-sub {
      color: rgba(255,255,255,0.78);
      margin: 0 auto 40px;
    }

    /* ===========================
       FOOTER
    =========================== */
    .footer {
      background: var(--black);
      padding: 32px 28px;
    }

    .footer-inner {
      max-width: var(--max);
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
    }

    .footer-logo { height: 28px; width: auto; opacity: 0.45; }

    .footer-links {
      display: flex;
      align-items: center;
      gap: 24px;
    }
    .footer-links a {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.35);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      transition: color 0.2s;
    }
    .footer-links a:hover { color: rgba(255,255,255,0.7); }

    .footer-copy {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.2);
    }

    /* ===========================
